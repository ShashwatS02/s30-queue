{
  "name": "s30-queue",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "s30-queue",
      "workspaces": [
        "api",
        "worker",
        "web",
        "packages/*"
      ]
    },
    "api": {
      "version": "1.0.0"
    },
    "node_modules/@s30-queue/shared-types": {
      "resolved": "packages/shared-types",
      "link": true
    },
    "node_modules/@s30-queue/shared-utils": {
      "resolved": "packages/shared-utils",
      "link": true
    },
    "node_modules/api": {
      "resolved": "api",
      "link": true
    },
    "node_modules/web": {
      "resolved": "web",
      "link": true
    },
    "node_modules/worker": {
      "resolved": "worker",
      "link": true
    },
    "packages/shared-types": {
      "name": "@s30-queue/shared-types",
      "version": "1.0.0"
    },
    "packages/shared-utils": {
      "name": "@s30-queue/shared-utils",
      "version": "1.0.0"
    },
    "web": {
      "version": "1.0.0"
    },
    "worker": {
      "version": "1.0.0"
    }
  }
}
